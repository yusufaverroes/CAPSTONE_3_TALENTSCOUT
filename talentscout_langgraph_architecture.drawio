<mxfile host="app.diagrams.net" version="24.0.0">
  <diagram name="Agent Graph" id="agent-graph">
    <mxGraphModel dx="1400" dy="800" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="780" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title2" value="TalentScout AI — Agent Graph (LangGraph runtime)" style="text;html=1;align=center;verticalAlign=middle;fontSize=20;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1120" height="36" as="geometry" />
        </mxCell>

        <mxCell id="g_start" value="START" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="70" y="150" width="90" height="60" as="geometry" />
        </mxCell>
        <mxCell id="g_sup" value="supervisor_node&lt;br&gt;&lt;br&gt;LLM · structured output&lt;br&gt;RoutingDecision (temp 0.0)&lt;br&gt;&lt;br&gt;STEP 1  in_scope?&lt;br&gt;STEP 2  request_satisfied?&lt;br&gt;STEP 3  next_agent&lt;br&gt;&lt;br&gt;out-of-scope → fixed refusal&lt;br&gt;then FINISH (no worker runs)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="230" y="105" width="260" height="180" as="geometry" />
        </mxCell>
        <mxCell id="g_router" value="route_from_supervisor" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="560" y="135" width="170" height="120" as="geometry" />
        </mxCell>

        <mxCell id="g_ret" value="retrieval  (ReAct)&lt;br&gt;search_by_skill /&lt;br&gt;by_category / summaries" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="820" y="70" width="240" height="70" as="geometry" />
        </mxCell>
        <mxCell id="g_cmp" value="comparison  (ReAct)&lt;br&gt;get_resume_full_text /&lt;br&gt;get_resume_summary" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="820" y="160" width="240" height="70" as="geometry" />
        </mxCell>
        <mxCell id="g_smz" value="summarizer  (ReAct)&lt;br&gt;get_resume_full_text /&lt;br&gt;get_resume_summary" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="820" y="250" width="240" height="70" as="geometry" />
        </mxCell>
        <mxCell id="g_end" value="END" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="615" y="330" width="90" height="60" as="geometry" />
        </mxCell>

        <mxCell id="ge0" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;" edge="1" parent="1" source="g_start" target="g_sup"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ge1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;" edge="1" parent="1" source="g_sup" target="g_router"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ge2" value="next_agent = retrieval" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;fontSize=10;" edge="1" parent="1" source="g_router" target="g_ret"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ge3" value="= comparison" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;fontSize=10;" edge="1" parent="1" source="g_router" target="g_cmp"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ge4" value="= summarizer" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;fontSize=10;" edge="1" parent="1" source="g_router" target="g_smz"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ge5" value="FINISH / loop-break / hop-cap" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;fontSize=10;fontStyle=1;strokeColor=#b85450;" edge="1" parent="1" source="g_router" target="g_end"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ge6" value="return" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;dashed=1;fontSize=10;exitX=0;exitY=0.5;entryX=1;entryY=0.15;" edge="1" parent="1" source="g_ret" target="g_sup"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ge7" value="return" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;dashed=1;fontSize=10;exitX=0;exitY=0.5;entryX=1;entryY=0.85;" edge="1" parent="1" source="g_cmp" target="g_sup"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ge8" value="return" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;dashed=1;fontSize=10;exitX=0;exitY=0.5;entryX=0.5;entryY=1;" edge="1" parent="1" source="g_smz" target="g_sup"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="g_note" value="route_from_supervisor — END if (in order):&lt;br&gt;&lt;br&gt;1.  next_agent == FINISH&lt;br&gt;     (also covers out-of-scope refusal)&lt;br&gt;2.  loop-breaker: next_agent ==&lt;br&gt;     the worker that just ran&lt;br&gt;3.  worker hops ≥ MAX_SUPERVISOR_HOPS (5)&lt;br&gt;&lt;br&gt;else → route to the chosen worker" style="shape=note;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;align=left;spacingLeft=10;verticalAlign=top;spacingTop=8;size=18;" vertex="1" parent="1">
          <mxGeometry x="230" y="330" width="350" height="190" as="geometry" />
        </mxCell>

        <mxCell id="g_state_t" value="Shared AgentState — channels &amp;amp; reducers (sequential writes across hops accumulate, not overwrite)" style="text;html=1;align=left;verticalAlign=middle;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="560" width="1000" height="26" as="geometry" />
        </mxCell>
        <mxCell id="g_state" value="messages           add_messages — append new turns, de-dup by id (only the worker&#39;s final answer returns upward)&lt;br&gt;next_agent         plain — replaced every hop (routing target)&lt;br&gt;agent_path         operator.add — concatenate; its length is the worker-hop counter for the hard cap&lt;br&gt;retrieved_sources  operator.add — accumulate {resume_id, category, section, snippet, score}&lt;br&gt;category_filter    plain — injected once at graph entry (sidebar filter; empty = whole corpus)&lt;br&gt;token_usage        custom sum — input + output tokens across every LLM call (supervisor + workers)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontSize=12;align=left;spacingLeft=12;verticalAlign=top;spacingTop=10;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="80" y="590" width="1000" height="160" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
