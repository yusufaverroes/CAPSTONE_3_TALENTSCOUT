# Template for Streamlit secrets.
# Copy this file to .streamlit/secrets.toml and fill in real values.
# secrets.toml is gitignored — never commit it.
#
# For Streamlit Cloud deployment, paste these key/value pairs into
# the App settings → Secrets panel (TOML format is accepted directly).

# --- OpenAI ---
OPENAI_API_KEY = "sk-..."

# --- Qdrant Cloud ---
QDRANT_URL = "https://YOUR-CLUSTER-ID.qdrant.io:6333"
QDRANT_API_KEY = "..."

# --- Langfuse Cloud (optional) ---
LANGFUSE_PUBLIC_KEY = "pk-lf-..."
LANGFUSE_SECRET_KEY = "sk-lf-..."
LANGFUSE_HOST = "https://cloud.langfuse.com"
